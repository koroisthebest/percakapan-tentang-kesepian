<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Percakapan Tentang Kesepian</title>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=Inter:wght@400;500;600&display=swap" />
<style>
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    min-height: 100vh;
    background:
      linear-gradient(180deg, rgba(10,14,26,0.28) 0%, rgba(10,14,26,0.42) 45%, rgba(10,14,26,0.62) 100%),
      url('data:image/webp;base64,') center top / cover no-repeat fixed;
    background-color: #0F1422;
    font-family: 'Inter', sans-serif;
    color: #EDEAE6;
    padding-bottom: 140px;
  }
  .stars {
    position: fixed; inset: 0; pointer-events: none; opacity: 0.15;
    background-image:
      radial-gradient(1px 1px at 20% 30%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 70% 15%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 40% 60%, rgba(255,255,255,0.35), transparent),
      radial-gradient(1px 1px at 85% 70%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 10% 80%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1px 1px at 60% 40%, rgba(255,255,255,0.3), transparent);
    background-size: 100% 100%;
  }
  header { padding: 56px 24px 28px; text-align: center; }
  .eyebrow {
    font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase;
    color: #E8A660; font-weight: 500; margin-bottom: 14px;
  }
  h1 {
    font-family: 'Fraunces', serif; font-weight: 600; font-style: italic;
    font-size: clamp(28px, 5.5vw, 46px); margin: 0; color: #F5F1E8; line-height: 1.15;
    text-shadow: 0 2px 16px rgba(10,14,26,0.5);
  }
  header p {
    margin-top: 16px; color: #16213E; font-size: 15px; max-width: 480px;
    margin-left: auto; margin-right: auto; line-height: 1.7; font-weight: 500;
    text-shadow: 0 1px 8px rgba(255,255,255,0.35);
  }

  .composer-wrap { max-width: 540px; margin: 0 auto 60px; padding: 0 24px; }
  .card {
    background: rgba(245, 241, 232, 0.88);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(232, 166, 96, 0.35);
    border-radius: 12px; padding: 22px 22px 16px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.35);
  }
  textarea {
    width: 100%; resize: none; border: none; outline: none; background: transparent;
    font-family: 'Inter', sans-serif; font-size: 15px; line-height: 1.7; color: #16213E;
  }
  textarea::placeholder { color: #5B6584; }
  .card-footer {
    display: flex; justify-content: space-between; align-items: center; margin-top: 10px;
    border-top: 1px solid rgba(22,33,62,0.12); padding-top: 12px;
  }
  .counter { font-size: 12px; color: #3B4568; }
  .counter.limit { color: #B23A2E; }
  button#postBtn {
    background: linear-gradient(135deg, #E8A660, #D48A4A); color: #1C1508; border: none;
    border-radius: 8px; padding: 10px 20px; font-family: 'Inter', sans-serif; font-weight: 600;
    font-size: 13px; cursor: pointer; transition: opacity 0.15s ease;
  }
  button#postBtn:disabled { background: #3A3F52; color: #6E7590; cursor: default; }
  button#postBtn:hover:not(:disabled) { opacity: 0.88; }
  .error { color: #E08674; font-size: 13px; margin-top: 10px; text-align: center; }
  .hint {
    font-size: 11.5px; color: #1E2A4A; text-align: center; margin-top: 14px; line-height: 1.6;
    text-shadow: 0 1px 6px rgba(255,255,255,0.4);
  }

  .wall { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .status {
    text-align: center; color: #1E2A4A; text-shadow: 0 1px 6px rgba(255,255,255,0.4);
  }
  .empty { text-align: center; color: #6E7590; padding: 40px 0; }
  .empty .big { font-family: 'Fraunces', serif; font-style: italic; font-size: 22px; color: #16213E; }
  .grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 20px; padding-top: 8px;
  }
  .note {
    position: relative; padding: 20px 18px 16px; border-radius: 10px;
    background: rgba(237, 234, 230, 0.045);
    border: 1px solid rgba(232, 166, 96, 0.14);
    box-shadow: 0 10px 26px rgba(0,0,0,0.3);
    min-height: 110px; color: #EDEAE6;
    opacity: 1; transition: opacity 0.6s ease;
  }
  .note.fading { opacity: 0; }
  .note p {
    font-family: 'Inter', sans-serif; font-size: 13.5px; line-height: 1.65; margin: 0 0 14px;
    white-space: pre-wrap; word-break: break-word; color: #E4E1DA;
  }
  .note .meta {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 11.5px; color: #6E7590;
  }
  .note .report {
    background: none; border: none; color: #5C6280; font-size: 11px; cursor: pointer;
    text-decoration: underline; text-underline-offset: 2px; padding: 0;
  }
  .note .report:hover { color: #E08674; }
  .note .report.done { color: #7BA98A; text-decoration: none; cursor: default; }

  .help-banner {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 10;
    background: rgba(15, 20, 34, 0.92); backdrop-filter: blur(6px);
    border-top: 1px solid rgba(232, 166, 96, 0.25);
    padding: 12px 20px; text-align: center; font-size: 12.5px; color: #C7CBDB;
  }
  .help-banner a { color: #E8A660; text-decoration: none; font-weight: 600; }
  .help-banner a:hover { text-decoration: underline; }
  .help-banner strong { color: #F5F1E8; }

  @media (max-width: 480px) {
    .help-banner { font-size: 11.5px; padding: 10px 14px; }
  }
</style>
</head>
<body>
  <div class="stars"></div>

  <header>
    <div class="eyebrow">ruang aman &middot; tanpa nama</div>
    <h1>Percakapan Tentang Kesepian</h1>
    <p>Tulis apa yang kamu rasain. Nggak perlu nama, nggak perlu alasan yang jelas.
       Begitu dikirim, ceritamu akan muncul di dinding — bareng cerita orang lain yang juga lagi merasa sendirian.</p>
  </header>

  <div class="composer-wrap">
    <div class="card">
      <textarea id="msgInput" rows="4" maxlength="300" placeholder="Apa yang lagi kamu rasain malam ini?"></textarea>
      <div class="card-footer">
        <span class="counter" id="counter">0/300</span>
        <button id="postBtn" disabled>bagikan</button>
      </div>
    </div>
    <p class="error" id="errorMsg" style="display:none;"></p>
    <p class="hint">Anonim sepenuhnya — nggak ada nama, akun, atau data pribadi yang disimpan.<br/>
       Curhatan ini bisa dilihat siapa aja yang buka halaman ini.</p>
  </div>

  <div class="wall">
    <div id="status" class="status">memuat...</div>
    <div id="grid" class="grid" style="display:none;"></div>
    <div id="empty" class="empty" style="display:none;">
      <p class="big">belum ada cerita di sini...</p>
      <p style="font-size:13px;">jadi yang pertama berbagi.</p>
    </div>
  </div>

  <div class="help-banner">
    Kalau kamu lagi butuh bantuan segera: hubungi <strong>119 ext. 8</strong> (Healing119 / SEJIWA — gratis &amp; rahasia, 24 jam)
    atau kunjungi <a href="https://healing119.id" target="_blank" rel="noopener">healing119.id</a>. Kamu nggak sendirian.
  </div>

  <!-- ====== FIREBASE SETUP ======
    1. Buat project gratis di https://console.firebase.google.com
    2. Aktifin "Firestore Database" (mode production)
    3. Ambil config dari Project Settings > General > Your apps > SDK setup and configuration
    4. Paste config-nya di bawah, ganti semua placeholder "YOUR_..."

    Firestore Security Rules (publik bisa baca+tulis pesan & laporan, tapi nggak bisa hapus/edit):

    rules_version = '2';
    service cloud.firestore {
      match /databases/{database}/documents {
        match /messages/{msgId} {
          allow read: if true;
          allow create: if request.resource.data.text is string
                        && request.resource.data.text.size() <= 300
                        && request.resource.data.keys().hasOnly(['text', 'ts']);
          allow update, delete: if false;
        }
        match /reports/{reportId} {
          allow read: if false;
          allow create: if request.resource.data.keys().hasOnly(['messageId', 'text', 'ts']);
          allow update, delete: if false;
        }
      }
    }

    PENTING: cek koleksi "reports" di Firebase Console secara berkala buat pantau
    konten yang dilaporkan — ini nggak otomatis nge-hapus apa pun, cuma nge-flag.
  -->
  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
    import {
      getFirestore, collection, addDoc, query, orderBy, limit, onSnapshot, serverTimestamp
    } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

    const firebaseConfig = {
      apiKey: "YOUR_API_KEY",
      authDomain: "YOUR_PROJECT.firebaseapp.com",
      projectId: "YOUR_PROJECT_ID",
      storageBucket: "YOUR_PROJECT.appspot.com",
      messagingSenderId: "YOUR_SENDER_ID",
      appId: "YOUR_APP_ID"
    };

    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);
    const messagesRef = collection(db, "messages");
    const reportsRef = collection(db, "reports");

    const SLOT_COUNT = 10;
    const CYCLE_MS = 6000;

    const input = document.getElementById("msgInput");
    const counter = document.getElementById("counter");
    const postBtn = document.getElementById("postBtn");
    const errorMsg = document.getElementById("errorMsg");
    const statusEl = document.getElementById("status");
    const gridEl = document.getElementById("grid");
    const emptyEl = document.getElementById("empty");

    let pool = [];
    let displayedIds = [];
    let justPostedId = null;
    let cycleTimer = null;
    let firstLoad = true;

    input.addEventListener("input", () => {
      const len = input.value.length;
      counter.textContent = `${len}/300`;
      counter.classList.toggle("limit", len >= 300);
      postBtn.disabled = input.value.trim().length === 0;
    });

    input.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "Enter") postBtn.click();
    });

    postBtn.addEventListener("click", async () => {
      const text = input.value.trim().slice(0, 300);
      if (!text) return;
      postBtn.disabled = true;
      postBtn.textContent = "mengirim...";
      errorMsg.style.display = "none";
      try {
        const docRef = await addDoc(messagesRef, { text, ts: serverTimestamp() });
        justPostedId = docRef.id;
        input.value = "";
        counter.textContent = "0/300";
      } catch (e) {
        errorMsg.textContent = "Gagal mengirim. Coba lagi ya.";
        errorMsg.style.display = "block";
        console.error(e);
      } finally {
        postBtn.textContent = "bagikan";
        postBtn.disabled = input.value.trim().length === 0;
      }
    });

    function pickRandomUnused() {
      const unused = pool.filter(m => !displayedIds.includes(m.id));
      const source = unused.length > 0 ? unused : pool;
      if (source.length === 0) return null;
      return source[Math.floor(Math.random() * source.length)];
    }

    function renderSlot(slotIndex, msg) {
      const card = gridEl.children[slotIndex];
      if (!card) return;
      const p = card.querySelector('p');
      const meta = card.querySelector('.meta span');
      const reportBtn = card.querySelector('.report');
      p.textContent = msg ? msg.text : "";
      meta.textContent = msg ? "anonim" : "";
      card.dataset.msgId = msg ? msg.id : "";
      reportBtn.classList.remove("done");
      reportBtn.textContent = "laporkan";
      reportBtn.disabled = false;
      displayedIds[slotIndex] = msg ? msg.id : null;
    }

    function buildGrid() {
      gridEl.innerHTML = "";
      for (let i = 0; i < SLOT_COUNT; i++) {
        const card = document.createElement("div");
        card.className = "note";
        card.innerHTML = `
          <p></p>
          <div class="meta">
            <span>anonim</span>
            <button class="report">laporkan</button>
          </div>
        `;
        card.querySelector(".report").addEventListener("click", async (e) => {
          const btn = e.currentTarget;
          const msgId = card.dataset.msgId;
          if (!msgId || btn.disabled) return;
          btn.disabled = true;
          btn.textContent = "melapor...";
          try {
            await addDoc(reportsRef, {
              messageId: msgId,
              text: card.querySelector('p').textContent,
              ts: serverTimestamp()
            });
            btn.textContent = "terlapor";
            btn.classList.add("done");
          } catch (err) {
            btn.textContent = "gagal, coba lagi";
            btn.disabled = false;
            console.error(err);
          }
        });
        gridEl.appendChild(card);
      }
    }

    function fillInitialSlots() {
      displayedIds = new Array(SLOT_COUNT).fill(null);
      const count = Math.min(SLOT_COUNT, pool.length);
      const shuffled = [...pool].sort(() => Math.random() - 0.5);
      for (let i = 0; i < count; i++) renderSlot(i, shuffled[i]);
      for (let i = count; i < SLOT_COUNT; i++) {
        gridEl.children[i].style.visibility = "hidden";
      }
    }

    function insertJustPosted() {
      if (!justPostedId) return;
      const msg = pool.find(m => m.id === justPostedId);
      if (!msg) return;
      let slot = displayedIds.findIndex(id => id === null);
      if (slot === -1) slot = Math.floor(Math.random() * SLOT_COUNT);
      const card = gridEl.children[slot];
      card.style.visibility = "visible";
      card.classList.add("fading");
      setTimeout(() => {
        renderSlot(slot, msg);
        requestAnimationFrame(() => card.classList.remove("fading"));
      }, 300);
      justPostedId = null;
    }

    function startCycle() {
      if (cycleTimer) clearInterval(cycleTimer);
      cycleTimer = setInterval(() => {
        if (pool.length <= SLOT_COUNT) return;
        const visibleSlots = displayedIds
          .map((id, idx) => idx)
          .filter(idx => gridEl.children[idx].style.visibility !== "hidden");
        if (visibleSlots.length === 0) return;
        const slot = visibleSlots[Math.floor(Math.random() * visibleSlots.length)];
        const card = gridEl.children[slot];
        card.classList.add("fading");
        setTimeout(() => {
          const next = pickRandomUnused();
          renderSlot(slot, next);
          card.classList.remove("fading");
        }, 600);
      }, CYCLE_MS);
    }

    const q = query(messagesRef, orderBy("ts", "desc"), limit(200));
    onSnapshot(q, (snapshot) => {
      statusEl.style.display = "none";
      pool = snapshot.docs.map(d => {
        const data = d.data();
        return { id: d.id, text: data.text || "", ts: data.ts && data.ts.toMillis ? data.ts.toMillis() : Date.now() };
      });

      if (pool.length === 0) {
        gridEl.style.display = "none";
        emptyEl.style.display = "block";
        return;
      }
      emptyEl.style.display = "none";
      gridEl.style.display = "grid";

      if (firstLoad) {
        buildGrid();
        fillInitialSlots();
        startCycle();
        firstLoad = false;
      } else if (justPostedId) {
        insertJustPosted();
      }
    }, (err) => {
      statusEl.textContent = "Gagal memuat. Cek koneksi / config Firebase.";
      console.error(err);
    });
  </script>
</body>
</html>
